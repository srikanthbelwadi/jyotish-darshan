{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "functions": {
    "api/**/*.js": {
      "includeFiles": "{public/sweph/**,node_modules/swisseph-wasm/**/*.wasm}"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/__/auth/(.*)",
      "destination": "https://jyotish-darshan-ce2a2.firebaseapp.com/__/auth/$1"
    },
    {
      "source": "/(.*)swisseph\\.wasm",
      "destination": "/swisseph.wasm"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "unsafe-none"
        }
      ]
    }
  ]
}