function t(path,lang){const S=STRINGS[lang]||STRINGS.en;if(S[path]!==undefined)return S[path];const k=path.split('.');let v=S;for(const p of k){v=v?.[p];}if(v!==undefined&&typeof v!=='object')return v;const E=STRINGS.en;if(E[path]!==undefined)return E[path];let e=E;for(const p of k){e=e?.[p];}return(e!==undefined&&typeof e!=='object')?e:path;}

